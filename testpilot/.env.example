# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL="file:./dev.db"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Worker
PORT=3001
MAX_RETRY_DEPTH=2
COVERAGE_THRESHOLD=80

# Docker
DOCKER_SOCKET=/var/run/docker.sock
SANDBOX_IMAGE=gradle:8.5-jdk21

# Web
VITE_API_URL=http://localhost:3001
